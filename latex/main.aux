\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces High-level RVT-Swarm pipeline. Local observations are encoded into an interaction graph, processed by attention-based message passing, and decoded into three outputs: velocity command~$\mathbf  {u}_i$, topology logits~$\bm  {\ell }_\tau $ via neighbourhood consensus, and per-topology recoverability scores~$\hat  {R}_\tau $. The counterfactual selector and CBF-QP shield (dashed, red) operate at inference time only.}}{3}{figure.caption.2}\protected@file@percent }
\newlabel{fig:architecture}{{1}{3}{High-level RVT-Swarm pipeline. Local observations are encoded into an interaction graph, processed by attention-based message passing, and decoded into three outputs: velocity command~$\bfu _i$, topology logits~$\bm {\ell }_\tau $ via neighbourhood consensus, and per-topology recoverability scores~$\hat {R}_\tau $. The counterfactual selector and CBF-QP shield (dashed, red) operate at inference time only}{figure.caption.2}{}}
\newlabel{fig:architecture@cref}{{[figure][1][]1}{[1][2][]3}{}{}{}}
