\citation{grad_scale}
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Detailed architecture of the \textbf  {Recoverability Field Network} (RFN). \emph  {Left}: each robot's 67-dim observation is assembled from ego state, goal/formation error, obstacle features, 36-ray LiDAR, and topology encoding. \emph  {Centre}: a linear encoder projects to 128-dim, then three attention-weighted graph layers refine node embeddings using 11-dim edge features. \emph  {Right} (purple region): four output heads decode velocity commands, per-topology recoverability scores, epistemic uncertainty, and consensus topology logits. Adjusted scores $\tilde  {r}_\tau $ modulate downstream topology selection and shield activation. Gradient scaling (red) protects the backbone from auxiliary losses.}}{4}{figure.caption.3}\protected@file@percent }
\newlabel{fig:rfn}{{2}{4}{Detailed architecture of the \textbf {Recoverability Field Network} (RFN). \emph {Left}: each robot's 67-dim observation is assembled from ego state, goal/formation error, obstacle features, 36-ray LiDAR, and topology encoding. \emph {Centre}: a linear encoder projects to 128-dim, then three attention-weighted graph layers refine node embeddings using 11-dim edge features. \emph {Right} (purple region): four output heads decode velocity commands, per-topology recoverability scores, epistemic uncertainty, and consensus topology logits. Adjusted scores $\tilde {r}_\tau $ modulate downstream topology selection and shield activation. Gradient scaling (red) protects the backbone from auxiliary losses}{figure.caption.3}{}}
\newlabel{fig:rfn@cref}{{[figure][2][]2}{[1][3][]4}{}{}{}}
