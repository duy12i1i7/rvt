\newlabel{sec:rfn@cref}{{[subsection][1][4]\mbox  {IV-A}}{[1][3][]3}{}{}{}}
\newlabel{eq:rfn_adjusted}{{5}{3}{Recoverability Field Network (RFN)}{equation.5}{}}
